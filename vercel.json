{
  "rewrites": [
    { "source": "/dashboard",      "destination": "/dashboard.html" },
    { "source": "/auth-callback",  "destination": "/auth-callback.html" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ucm-thothi-developers-projects.vercel.app" }],
      "destination": "https://ucm.thothi.app/$1",
      "permanent": true
    }
  ]
}
